PORT=5000

# Neon PostgreSQL connection string (copy from Neon console → Connection string)
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://neondb_owner:<password>@ep-<name>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

NODE_ENV=development

# Set to "true" to force SSL for non-Neon hosted Postgres (optional)
DB_SSL=false

# Connection pool settings (optional – defaults shown)
POOL_MAX=10
POOL_IDLE_TIMEOUT=30000
POOL_CONNECTION_TIMEOUT=2000
